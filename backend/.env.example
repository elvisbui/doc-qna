# ── LLM Provider ──────────────────────────────────────────────
# Options: "ollama", "anthropic", "openai", "cloudflare"
LLM_PROVIDER=ollama

# ── Ollama (self-hosted, free) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_AUTO_PULL=true

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Cloudflare Workers AI ─────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_LLM_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
CLOUDFLARE_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5

# ── Embedding Provider ────────────────────────────────────────
# Options: "openai", "ollama", "cloudflare", "chromadb"
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_CACHE_SIZE=128

# ── Chunking & Retrieval ──────────────────────────────────────
# Chunking: "fixed" (sliding window) or "semantic" (paragraph-based)
CHUNKING_STRATEGY=fixed
# Retrieval: "vector" (embedding only) or "hybrid" (vector + BM25)
RETRIEVAL_STRATEGY=vector

# ── ChromaDB ──────────────────────────────────────────────────
# Mode: "embedded" (local PersistentClient) or "client" (remote server)
CHROMA_MODE=embedded
CHROMA_PERSIST_DIR=./chroma_data
# Remote server settings (only used when CHROMA_MODE=client)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── LLM Generation Parameters ────────────────────────────────
LLM_TEMPERATURE=0.7
LLM_TOP_P=1.0
LLM_MAX_TOKENS=2048
# Custom system prompt (empty = use built-in default)
SYSTEM_PROMPT=

# ── Security ──────────────────────────────────────────────────
# Comma-separated API keys for authentication (empty = auth disabled)
API_KEYS=
# Rate limiting (disabled by default)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ── Multi-User ────────────────────────────────────────────────
# Enable per-user document isolation
MULTI_USER_ENABLED=false

# ── Plugins & Packs ───────────────────────────────────────────
PLUGINS_DIR=plugins
PACKS_DIR=../packs

# ── Server ────────────────────────────────────────────────────
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Cache TTL for downloaded packs (seconds)
PACKS_CACHE_TTL=3600
